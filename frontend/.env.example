# Frontend Environment Variables Configuration
# Since Flutter uses dart-define, you can use these by passing them to the run command:
# flutter run --dart-define=API_BASE_URL=http://10.0.2.2:8080/api/v1

API_BASE_URL=http://localhost:8080/api/v1
# For Android emulator connecting to local backend, use http://10.0.2.2:8080/api/v1

# Note on Firebase:
# 1. Place google-services.json in frontend/android/app/
# 2. Place GoogleService-Info.plist in frontend/ios/Runner/

# Note on Google Maps:
# Add your Google Maps API key to:
# - frontend/android/app/src/main/AndroidManifest.xml
#   <meta-data android:name="com.google.android.geo.API_KEY" android:value="YOUR_API_KEY"/>
# - frontend/ios/Runner/AppDelegate.swift
